      <aliases enabled='yes' />
      <column caption='Performance Level' datatype='string' name='[Calculation_4747828299534337]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [horsepower] &lt; 150 THEN &quot;Low Performance&quot;&#10;&#10;ELSEIF [horsepower] &gt;= 150 AND [horsepower] &lt;= 300 THEN &quot;Mid Performance&quot;&#10;&#10;ELSEIF [horsepower] &gt;= 301 AND [horsepower] &lt;= 500 THEN &quot;High Performance&quot;&#10;&#10;ELSE &quot;Very High Performance&quot;&#10;&#10;END' />
      </column>
      <column caption='Range Level' datatype='string' name='[Calculation_4747828300042242]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [range_miles] &lt; 200 THEN &quot;Low Range&quot;&#10;&#10;ELSEIF [range_miles] &gt;= 200 AND [range_miles] &lt;= 300 THEN &quot;Mid Range&quot;&#10;&#10;ELSEIF [range_miles] &gt;= 301 AND [range_miles] &lt;= 400 THEN &quot;High Range&quot;&#10;&#10;ELSE &quot;Very High Range&quot;&#10;&#10;END' />
      </column>
